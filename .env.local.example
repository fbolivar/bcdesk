# ============================================================
# BCDesk — Variables de entorno
# Copia este archivo a .env.local (dev) o configúralas en Vercel (prod).
# NUNCA commitees valores reales: .env*.local está en .gitignore.
# ============================================================

# --- Supabase (REQUERIDO) ---------------------------------
# Vienen del Dashboard: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon_key>
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>          # SECRETO — solo server
# Debe COINCIDIR con el JWT secret del proyecto (Settings > API > JWT).
# La auth propia firma tokens con esta clave y PostgREST los valida con ella.
SUPABASE_JWT_SECRET=<jwt_secret>                       # SECRETO — solo server

# --- URLs del sitio (REQUERIDO) ---------------------------
NEXT_PUBLIC_APP_URL=https://tu-dominio.com
NEXT_PUBLIC_SITE_URL=https://tu-dominio.com

# --- IA (REQUERIDO para asistente de tickets) -------------
ANTHROPIC_API_KEY=sk-ant-...
# Opcionales (proveedores alternativos):
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Email saliente vía Google Workspace SMTP (REQUERIDO) -----------
# GMAIL_USER = cuenta PRINCIPAL con login (la que autentica el SMTP), NO el alias.
# App Password: myaccount.google.com/apppasswords (requiere Verificación en 2 pasos).
# SUPPORT_EMAIL = alias visible desde el que se envía y llegan respuestas.
GMAIL_USER=tucuenta@fernandobolivar.app               # cuenta principal (login)
GMAIL_APP_PASSWORD=<app_password_16_chars>            # SECRETO — solo server
SUPPORT_EMAIL=soporte@fernandobolivar.app             # alias visible
MAIL_FROM="HexDesk <soporte@fernandobolivar.app>"     # opcional; por defecto usa SUPPORT_EMAIL

# --- Push notifications (PWA) -----------------------------
# Genera con: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=<vapid_public>
VAPID_PRIVATE_KEY=<vapid_private>                      # SECRETO
VAPID_SUBJECT=mailto:admin@tu-dominio.com
VAPID_EMAIL=admin@tu-dominio.com

# --- Cron / seguridad de endpoints ------------------------
CRON_SECRET=<random>                                   # SECRETO

# --- Email entrante (email → ticket vía Google Apps Script) ---
# El Apps Script del buzón soporte@ envía cada correo nuevo a
# /api/email/inbound con este secreto en el header x-webhook-secret.
EMAIL_INBOUND_SECRET=<random>                          # SECRETO

# --- Pagos Stripe (opcional) ------------------------------
STRIPE_SECRET_KEY=sk_live_...                          # SECRETO
STRIPE_WEBHOOK_SECRET=whsec_...                        # SECRETO

# --- WhatsApp (opcional) ----------------------------------
WHATSAPP_VERIFY_TOKEN=<random>                         # SECRETO
